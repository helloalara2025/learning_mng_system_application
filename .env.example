# ═══════════════════════════════════════════════════════════════════════════
# KAMBAZ BACKEND ENVIRONMENT VARIABLES - Created by Alara
# ═══════════════════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values

# MongoDB Atlas connection string
DATABASE_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/kambaz

# Frontend URL (Vercel deployment)
CLIENT_URL=https://your-app.vercel.app

# Server domain (for cookies) - NO https://
SERVER_URL=your-app.onrender.com

# Environment: development or production
SERVER_ENV=production

# Session secret (use a long random string)
SESSION_SECRET=your-super-secret-session-key
